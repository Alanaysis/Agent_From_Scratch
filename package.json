{
  "name": "claude-code-lite",
  "version": "0.1.0",
  "description": "A minimal, installable CLI runtime inspired by Claude Code's architecture.",
  "type": "module",
  "bin": {
    "claude-code-lite": "./bin/claude-code-lite.js"
  },
  "files": [
    "bin",
    "skills",
    "app/main.js",
    "app/main.js.map",
    "README.md",
    ".env.example",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild ./app/main.ts --bundle --platform=node --format=esm --outfile=./bin/claude-code-lite.js --external:playwright --external:chromium-bidi --external:readline/promises && cp -r ./skills ./bin/ 2>/dev/null || true",
    "build:exe": "mkdir -p ./dist && bun build --compile --outfile ./dist/claude-code-lite ./app/main.ts",
    "dev": "bun ./app/main.ts",
    "typecheck": "tsc -p tsconfig.json",
    "check": "bun run build && node ./bin/claude-code-lite.js --help",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agent",
    "cli",
    "llm",
    "tools",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "c8": "^11.0.0",
    "electron": "^41.2.0",
    "is-dark": "^1.0.4",
    "picocolors": "^1.1.1",
    "playwright": "^1.59.1"
  }
}
